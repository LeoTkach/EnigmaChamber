@{
    var nav = ViewData["ActiveNav"]?.ToString();
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EnigmaChamber</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/enigma-theme.css" asp-append-version="true" />
</head>
<body class="enigma-body">
<div class="enigma-shell">
    <aside class="enigma-sidebar">
        <div class="sidebar-screw top-left"></div>
        <div class="sidebar-screw top-right"></div>
        <div class="sidebar-screw bottom-left"></div>
        <div class="sidebar-screw bottom-right"></div>
        
        <div class="sidebar-header">
            <div class="brand-row">
                <div class="enigma-brand">ENIGMA CHAMBER</div>
                <div class="speaker-grill-horiz">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>
            </div>
            <div class="grill-row">
                <div class="speaker-grill-vert">
                    <span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
                <div class="speaker-dots">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
        
        <nav class="nav flex-column enigma-nav">
            <a class="nav-link @(nav == "home" ? "active" : "")" asp-page="/Index">Home</a>
            <a class="nav-link @(nav == "rooms" ? "active" : "")" asp-page="/Rooms/Index">Rooms</a>
            <a class="nav-link @(nav == "bookings" ? "active" : "")" asp-page="/Bookings/Index">Bookings</a>
            <a class="nav-link @(nav == "staff" ? "active" : "")" asp-page="/Staff/Index">Staff</a>
            <a class="nav-link @(nav == "results" ? "active" : "")" asp-page="/Results/Index">Results</a>
            <a class="nav-link @(nav == "stats" ? "active" : "")" asp-page="/Stats/Index">Stats</a>
            <a class="nav-link @(nav == "audit" ? "active" : "")" asp-page="/Audit/Index">Audit Log</a>
        </nav>
        
        <div class="admin-plaque">
            <div class="plaque-screw top-left"></div>
            <div class="plaque-screw top-right"></div>
            <div class="plaque-screw bottom-left"></div>
            <div class="plaque-screw bottom-right"></div>
            
            <div class="plaque-text">
                <div class="admin-title">SYSTEM ADMIN</div>
                <div class="admin-clearance">CLEARANCE</div>
            </div>
            
            <div class="plaque-paper">
                LVL 5
            </div>
        </div>
    </aside>
    <div class="enigma-screen-frame">
        <div class="enigma-screen-glass">
            <div class="crt-overlay"></div>
            <main class="enigma-main">
                <div class="osd-bar">
                    <span class="osd-left" id="osdTelemetry">SIG --% · SNR --.-dB · BUF --ms · TAPE A-03</span>
                    <span class="osd-right">
                        <span>Network Status: <span class="osd-status">Online</span></span>
                        <span class="osd-time" id="osdClock">--:--:--</span>
                    </span>
                </div>
                @RenderBody()
            </main>
        </div>
    </div>
</div>
<!-- barrel (fisheye) distortion filter -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <filter id="crtBarrel" filterUnits="objectBoundingBox" x="-0.2" y="-0.2" width="1.4" height="1.4" color-interpolation-filters="sRGB">
        <feImage href="data:image/png;base64," x="0" y="0" width="100%" height="100%"
                 preserveAspectRatio="none" result="map" />
        <feDisplacementMap in="SourceGraphic" in2="map" scale="55"
                           xChannelSelector="R" yChannelSelector="G" />
    </filter>
</svg>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const clock = document.getElementById('osdClock');
        const tick = () => {
            clock.textContent = new Date()
                .toLocaleString('uk-UA', { hour12: false })
                .replace(', ', ' ');
        };
        tick();
        setInterval(tick, 1000);

        // decorative telemetry: jittering junk values, no real meaning
        const telemetry = document.getElementById('osdTelemetry');
        const jitter = (base, spread, digits = 0) =>
            (base + (Math.random() - 0.5) * spread).toFixed(digits);
        const feed = () => {
            telemetry.textContent =
                `SIG ${jitter(91, 6)}% · SNR ${jitter(42, 3, 1)}dB · BUF ${jitter(9, 6)}ms · TAPE A-03`;
        };
        feed();
        setInterval(feed, 2500);
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
