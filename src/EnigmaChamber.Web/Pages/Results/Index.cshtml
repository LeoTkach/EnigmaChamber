@page
@model EnigmaChamber.Web.Pages.Results.IndexModel
@{
    ViewData["Title"] = "Results";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Results & Hall of Fame</h1>
        <p class="page-subtitle">Submit game results and view top records</p>
    </div>
    <button type="button" class="btn btn-enigma" data-bs-toggle="modal" data-bs-target="#resultModal">
        + Submit Result
    </button>
</div>

<div class="mb-4">
    <div class="d-flex flex-wrap gap-2">
        @foreach (var room in Model.Rooms)
        {
            <a asp-page="./Index" asp-route-SelectedRoomId="@room.Id"
               class="btn @(Model.SelectedRoomId == room.Id ? "btn-enigma" : "btn-outline-enigma")">
               @room.Name
            </a>
        }
    </div>
</div>

@if (Model.SelectedRoomId.HasValue)
{
    @if (!Model.HallOfFame.Any())
    {
        <div class="enigma-card empty-state">No successful records found for this room.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-enigma align-middle">
                <thead>
                <tr>
                    <th style="width: 50px;">RANK</th>
                    <th>DATE</th>
                    <th>TEAM / CUSTOMER</th>
                    <th>ELAPSED (MIN)</th>
                    <th>HINTS</th>
                </tr>
                </thead>
                <tbody>
                @{ var rank = 0; }
                @foreach (var r in Model.HallOfFame)
                {
                    rank++;
                    <tr>
                        <td class="mono fs-5 text-accent">@rank</td>
                        <td>@r.CompletedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                        <td class="fw-bold">@r.Booking.CustomerName</td>
                        <td class="mono">@r.FinalMinutes</td>
                        <td class="mono">@r.HintsUsed</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
}

<div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="false">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Save" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Submit Result</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div asp-validation-summary="ModelOnly" class="text-validation-error mb-2"></div>
                
                <div class="mb-3">
                    <label asp-for="Input.BookingId" class="form-label">Active Game</label>
                    <select asp-for="Input.BookingId" asp-items="Model.BookingOptions" class="form-select">
                        <option value="">-- Select Game --</option>
                    </select>
                    <div class="form-text text-muted">Only games currently "In Progress" are shown.</div>
                </div>
                
                <div class="form-check mb-3">
                    <input asp-for="Input.Success" class="form-check-input" />
                    <label asp-for="Input.Success" class="form-check-label text-success fw-bold">Success (Escaped)</label>
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label asp-for="Input.ElapsedMinutes" class="form-label"></label>
                        <input asp-for="Input.ElapsedMinutes" class="form-control" type="number" min="0" max="300" />
                        <span asp-validation-for="Input.ElapsedMinutes" class="field-validation-error"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label asp-for="Input.HintsUsed" class="form-label"></label>
                        <input asp-for="Input.HintsUsed" class="form-control" type="number" min="0" max="20" />
                        <span asp-validation-for="Input.HintsUsed" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Notes" class="form-label">Notes (Optional)</label>
                    <textarea asp-for="Input.Notes" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Input.Notes" class="field-validation-error"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-enigma" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-enigma">Submit</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
